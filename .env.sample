APP_ID="11"
PRIVATE_KEY_PATH="very/secure/location/gh_app_key.pem"
WEBHOOK_SECRET="secret"

# Comma-separated GitHub logins for PR authors treated as Copilot (see pull_request.user.login on a real Copilot PR).
# Leave unset or empty to disable Copilot-only automation.
# COPILOT_PR_AUTHOR_LOGINS="github-copilot[bot]"

# Optional. PRs whose title starts with this are skipped (default: "[WIP] ").
# WIP_TITLE_PREFIX="[WIP] "
